{
  "id": "xjsm",
  "name": "星际使命",
  "urlPattern": "^https?:\\/\\/star\\.jvplay\\.cn\\/v2\\/storage",
  "mode": "json",
  "processor": {
    "processor": "sceneDispatcher",
    "params": {
      "scenes": [
        {
          "name": "wallet",
          "when": "hasKey",
          "path": "objects",
          "key": "wallet",
          "then": {
            "processor": "setFields",
            "params": {
              "fields": {
                "objects[0].value": "{\"coin\":9999880,\"coupon\":9999880,\"gem\":9999880}"
              }
            }
          }
        },
        {
          "name": "bag",
          "when": "hasKey",
          "path": "objects",
          "key": "Bag",
          "then": {
            "processor": "setFields",
            "params": {
              "fields": {
                "data.weaponUnlocked": true
              }
            }
          }
        }
      ]
    }
  }
}
