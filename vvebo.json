{
  "name": "Vvebo Subscription Forward",
  "mode": "forward",
  "forwardUrl": "https://mock.forward1.workers.dev/forward/v1/purchase/iap/subscription",
  "method": "POST",
  "timeout": 10000,
  "forwardHeaders": {
    "Content-Type": "application/json; charset=utf-8",
    "X-Auth-Key": "{{x-auth-key}}"
  },
  "statusTexts": {
    "200": "OK",
    "201": "Created",
    "202": "Accepted",
    "204": "No Content",
    "400": "Bad Request",
    "401": "Unauthorized",
    "403": "Forbidden",
    "404": "Not Found",
    "500": "Internal Server Error",
    "502": "Bad Gateway",
    "503": "Service Unavailable"
  },
  "responseHeaders": {
    "server": "openresty",
    "content-type": "application/json; charset=utf-8"
  }
}
