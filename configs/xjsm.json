{
  "id": "xjsm",
  "name": "星际使命",
  "urlPattern": "^https?:\\/\\/star\\.jvplay\\.cn\\/v2\\/storage",
  "mode": "json",
  "processor": {
    "processor": "compose",
    "params": {
      "steps": [
        {
          "processor": "when",
          "params": {
            "condition": "hasKey",
            "path": "objects",
            "key": "wallet",
            "then": {
              "processor": "setFields",
              "params": {
                "fields": {
                  "objects[0].value": "{\"coin\":999988990,\"coupon\":999988990,\"gem\":999988990}"
                }
              }
            }
          }
        },
        {
          "processor": "when",
          "params": {
            "condition": "hasKey",
            "path": "objects",
            "key": "Bag",
            "then": {
              "processor": "setFields",
              "params": {
                "fields": {
                  "data.weaponUnlocked": true
                }
              }
            }
          }
        }
      ]
    }
  }
}
