{
  "id": "tophub",
  "name": "TopHub",
  "urlPattern": "(?:api[23]\\.tophub\\.(?:xyz|today|app)|tophub(?:2)?\\.(?:tophubdata\\.com|idaily\\.today))\\/account\\/sync",
  "mode": "json",
  "processor": {
    "processor": "compose",
    "params": {
      "steps": [
        {
          "processor": "setFields",
          "params": {
            "fields": {
              "error": 0,
              "status": 200,
              "data.is_vip": "1",
              "data.is_vip_now": 1,
              "data.vip_expired": "2099-12-31 23:59:59",
              "data.vip_type": "lifetime",
              "data.vip_level": 99
            }
          }
        }
      ]
    }
  }
}
