{
  "id": "qiujingapp",
  "name": "球竞APP",
  "urlPattern": "^https?:\\/\\/gateway-api\\.yizhilive\\.com\\/api\\/(?:v2\\/index\\/carouses\\/(?:3|6|8|11)|v3\\/index\\/all)",
  "mode": "json",
  "processor": {
    "processor": "sceneDispatcher",
    "params": {
      "scenes": [
        {
          "name": "carouselAds",
          "when": "pathMatch",
          "path": "/api/v2/index/carouses/",
          "then": {
            "processor": "clearArray",
            "params": {
              "path": "data"
            }
          }
        },
        {
          "name": "bannerAds",
          "when": "queryMatch",
          "param": "position",
          "value": "2",
          "then": {
            "processor": "clearArray",
            "params": {
              "path": "data.banners"
            }
          }
        }
      ]
    }
  }
}
