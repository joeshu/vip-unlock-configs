{
  "name": "KaDa 阅读 VIP Unlock",
  "mode": "json",
  "processor": {
    "processor": "compose",
    "params": {
      "steps": [
        {
          "processor": "setFields",
          "params": {
            "fields": {
              "data.unLock": true,
              "data.bookVip": 0,
              "data.bookSvip": 0,
              "data.price": 0,
              "data.vipPrice": 0,
              "data.subscribed": 1,
              "data.subscribeFlag": 1,
              "data.freeFlag": 1,
              "data.freeEndTime": 9999999999999,
              "data.abilitiesFlag": 31,
              "data.abilities": ["伴读", "拼音", "字卡", "答题", "朗读"]
            }
          }
        },
        {
          "processor": "setFields",
          "params": {
            "fields": {
              "data.trialReadingPages": "{{data.pageCount}}",
              "data.literacyTrialReadingPages": "{{data.pageCount}}"
            }
          }
        },
        {
          "processor": "setFields",
          "params": {
            "fields": {
              "data.collectInfo.subscribeStatus": 1
            }
          }
        },
        {
          "processor": "setFields",
          "params": {
            "fields": {
              "data.rating.userStar": 5
            }
          }
        },
        {
          "processor": "setFields",
          "params": {
            "fields": {
              "data.bookSrt.srtShowFlag": 1
            }
          }
        },
        {
          "processor": "mapArray",
          "params": {
            "path": "data.items",
            "fields": {
              "unLock": true,
              "bookVip": 0,
              "bookSvip": 0,
              "trialReadingPages": "{{pageCount}}",
              "literacyTrialReadingPages": "{{pageCount}}"
            }
          }
        }
      ]
    }
  }
}
